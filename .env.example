# Copy this file to .env for local development.
# Do not commit .env or credential JSON files.

# Keep true for local code-only dry runs.
# You can leave this true and still run the Sheets smoke test with:
# python -m src.main --sheets-smoke-test
JOB_TRACKER_DRY_RUN=true

# Google Sheet ID from the tracker Sheet URL.
GOOGLE_SHEET_ID=

# Local path to the downloaded service account JSON file.
# The credentials/ folder is ignored by Git.
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-credentials.json
